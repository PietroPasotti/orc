# AI backend: "copilot" (GitHub Copilot CLI) or "claude" (Anthropic)
COLONY_AI_CLI=copilot

# Anthropic API key (only needed if COLONY_AI_CLI=claude)
ANTHROPIC_API_KEY=your-anthropic-key-here

# GitHub token for Copilot CLI (only needed if COLONY_AI_CLI=copilot)
GH_TOKEN=your-gh-token-here

# Telegram bot credentials
COLONY_TELEGRAM_TOKEN=your-bot-token-here
COLONY_TELEGRAM_CHAT_ID=your-chat-id-here

# Optional: override the orc configuration directory (default: $CWD/orc)
# ORC_DIR=/path/to/your/orc/config
