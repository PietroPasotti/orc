# LLM provider credentials
# ORC uses the OpenAI-compatible API. Set the key for your chosen provider.
# The provider is configured in .orc/squads/<squad>.yaml (default: gemini).

# Gemini (default provider)
GEMINI_API_TOKEN=your-gemini-api-key-here

# OpenAI (alternative)
# OPENAI_API_KEY=your-openai-key-here

# GitHub Models (alternative)
# GH_TOKEN=your-gh-token-here

# Telegram bot credentials
COLONY_TELEGRAM_TOKEN=your-bot-token-here
COLONY_TELEGRAM_CHAT_ID=your-chat-id-here

# Optional: override the orc configuration directory (default: $CWD/.orc)
# ORC_DIR=/path/to/your/orc/config
